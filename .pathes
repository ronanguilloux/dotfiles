# Android
if [ -d "$HOME/Workspace/adt/sdk/" ] ; then
    export PATH=$PATH:$HOME/Workspace/adt/sdk/platform-tools:$HOME/Workspace/adt/sdk/tools
fi
if [ -d "/Applications/Android Studio.app/sdk" ] ; then
    export ANDROID_HOME="/Applications/Android Studio.app/sdk"
    export PATH="$ANDROID_HOME:$PATH"
fi
# Heroku
if [ -d "/usr/local/heroku/bin" ] ; then
    export PATH="/usr/local/heroku/bin:$PATH"
fi
# Golang
if [ -d "$HOME/Workspace/Go" ] ; then
    export GOPATH="$HOME/Workspace/Go"
    export GOROOT="/usr/local/go"
fi
# HOMEBREW
if [ -d "/usr/local/bin/php" ] ; then
    export PATH="/usr/local/bin:$PATH"
fi
# LIIP's PHP
#if [ -d "/usr/local/php5/bin" ] ; then
#    #Warning : liip's php-osx already includes pg_* commands
#    export PATH="/usr/local/php5/bin:$PATH"
#fi
# PHP's Composer
if [ -d "$HOME/.composer/vendor/bin" ] ; then
    export PATH="$HOME/.composer/vendor/bin:$PATH"
fi
# Ruby
if [ -d "$HOME/.rvm/bin" ] ; then
    export PATH="$HOME/.rvm/bin:$PATH"
fi
# Postgresql 9.4
if [ -d "/Applications/Postgres.app/Contents/Versions/9.4/bin" ] ; then
    export PATH="/Applications/Postgres.app/Contents/Versions/9.4/bin:$PATH"
fi
# Python 2.7 tools
if [ -d "/usr/local/Cellar/python/2.7.13/Frameworks/Python.framework/Versions/2.7/bin" ] ; then
    export PATH="/usr/local/Cellar/python/2.7.13/Frameworks/Python.framework/Versions/2.7/bin:$PATH"
fi

# Bins
if [ -d "/usr/local/sbin" ] ; then
    export PATH="/usr/local/sbin:$PATH"
fi
if [ -d "$HOME/Bin" ] ; then
    export PATH="$HOME/Bin:$PATH"
fi
if [ -d "$HOME/bin" ] ; then
    export PATH="$HOME/bin:$PATH"
fi
if [ -d "$HOME/localBin" ] ; then
    export PATH="$HOME/localBin:$PATH"
fi
# Python3
if [ -d "$HOME/Library/Python/3.9/bin" ] ; then
    export PATH="$HOME/Library/Python/3.9/bin:$PATH"
fi
# Antigravity
if [ -d "$HOME/.antigravity/antigravity/bin" ] ; then
    export PATH="$HOME/.antigravity/antigravity/bin:$PATH"
fi
# BibleCLI
if [ -d "$HOME/Code/Github/ScripturesApp/bin" ] ; then
    export PATH="$HOME/Code/Github/ScripturesApp/bin:$PATH"
fi
# Calible
if [ -d "/Applications/calibre.app/Contents/MacOS/" ] ; then
    export PATH="/Applications/calibre.app/Contents/MacOS:$PATH"
fi
# PHP 7.1
if [ -d "/usr/local/opt/php@7.1/bin" ] ; then
    export PATH="/usr/local/opt/php@7.1/bin:$PATH"
fi
if [ -d "/usr/local/opt/php@7.1/sbin" ] ; then
    export PATH="/usr/local/opt/php@7.1/sbin:$PATH"
fi
# Elasticsearch 5.6
if [ -d "/usr/local/opt/elasticsearch@5.6/bin" ] ; then
    export PATH="/usr/local/opt/elasticsearch@5.6/bin:$PATH"
fi
# NPM global packages
if [ -d "/usr/local/npm_packages" ] ; then
    export NPM_PACKAGES="/usr/local/npm_packages"
    export NODE_PATH="$NPM_PACKAGES/lib/node_modules:$NODE_PATH"
    export PATH="$NPM_PACKAGES/bin:$PATH"
fi
if [ -d "$HOME/.npm-packages/bin" ] ; then
    export PATH="$HOME/.npm-packages/bin:$PATH"
fi
# OpenCode
if [ -d "$HOME/.opencode/bin" ] ; then
    export PATH="$HOME/.opencode/bin:$PATH"
fi
# Local bin
if [ -d "$HOME/.local/bin" ] ; then
    export PATH="$HOME/.local/bin:$PATH"
fi
# Golang (system install)
if [ -d "/usr/local/go/bin" ] ; then
    export GOROOT="/usr/local/go"
    export GOPATH="/usr/local/go/bin"
    export PATH="$GOPATH:$PATH"
fi
if [ -d "$HOME/.opencode/" ] ; then
    export PATH=$HOME/.opencode/bin:$PATH
fi
if [ -d "$HOME/.antigravity-ide/antigravity-ide/" ] ; then
    export PATH="$HOME/.antigravity-ide/antigravity-ide/bin:$PATH"
fi
# this is the root folder where all globally installed node packages will  go
if [ -d "/usr/local/npm_packages" ] ; then
    export NPM_PACKAGES="/usr/local/npm_packages"
fi
if [ -d "$NPM_PACKAGES/lib/node_modules" ] ; then
    export NODE_PATH="$NPM_PACKAGES/lib/node_modules:$NODE_PATH"
fi
if [ -d "$NPM_PACKAGES/bin" ] ; then
    export PATH="$NPM_PACKAGES/bin:$PATH"
fi
if [ -d "$HOME/.npm-packages/bin" ] ; then
    export PATH="$HOME/.npm-packages/bin:$PATH"
fi
if [ -d "$HOME/Library/Python/3.9/bin" ] ; then
    export PATH="$HOME/Library/Python/3.9/bin:$PATH"
fi
# The next line updates PATH for the Google Cloud SDK.
if [ -f '$HOME/tmp/google-cloud-sdk/path.zsh.inc' ]; then . '$HOME/tmp/google-cloud-sdk/path.zsh.inc'; fi
# The next line enables shell command completion for gcloud.
if [ -f '$HOME/tmp/google-cloud-sdk/completion.zsh.inc' ]; then . '$HOME/tmp/google-cloud-sdk/completion.zsh.inc'; fi
if [ -d "$HOME/Documents/Ronan/Github/biblecli/bin" ] ; then
    export PATH="$HOME/Documents/Apps/gmail_shortcuts/bin:$PATH"
fi
